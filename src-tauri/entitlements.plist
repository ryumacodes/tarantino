<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Screen recording permissions -->
    <key>com.apple.security.device.screen-capture</key>
    <true/>
    
    <!-- Audio recording permissions for system audio -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    
    <!-- Microphone access -->
    <key>com.apple.security.device.microphone</key>
    <true/>
    
    <!-- Camera access -->
    <key>com.apple.security.device.camera</key>
    <true/>
    
    <!-- File system access for saving recordings -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    
    <!-- Access to Movies directory -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    
    <!-- Accessibility for mouse tracking -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    
    <!-- Network access for any web features -->
    <key>com.apple.security.network.client</key>
    <true/>
    
    <!-- Hardened runtime compatibility -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>